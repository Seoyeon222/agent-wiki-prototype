{
  "name": "llm-wiki-mcp-tools",
  "version": "1.0.0",
  "description": "MCP server exposing wiki_list/get/search/create/validate tools over a Markdown-based LLM Wiki",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/http.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.9.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "gray-matter": "^4.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
